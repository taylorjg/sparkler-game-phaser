{
  "name": "sparkler-game-phaser",
  "description": "Recreate Seb Lee-Delisle's sparkler game from the Royal Institution Christmas Lectures 2019 part 2 using Phaser 4 and TypeScript",
  "version": "0.0.29",
  "type": "module",
  "homepage": "https://taylorjg.github.io/sparkler-game-phaser/",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "open": "open https://taylorjg.github.io/sparkler-game-phaser"
  },
  "author": "Jonathan Taylor",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4"
  },
  "dependencies": {
    "audioworklet-polyfill": "^1.1.2",
    "loglevel": "^1.7.1",
    "phaser": "^4.2.1"
  },
  "allowScripts": {
    "fsevents@2.3.3": true
  }
}
